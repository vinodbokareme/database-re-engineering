# Copy this file to ".env" and fill in your database connection details.
# SchemaScribe auto-loads .env if python-dotenv is installed.
#
# IMPORTANT: SchemaScribe only ever READS your database. A read-only user is
# strongly recommended.

PGHOST=localhost
PGPORT=5432
PGDATABASE=my_database
PGUSER=readonly_user
PGPASSWORD=change-me

# Optional: sslmode (disable | allow | prefer | require | verify-ca | verify-full)
# PGSSLMODE=prefer